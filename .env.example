VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publishable-publica

# Na Vercel, o app também aceita automaticamente estes nomes comuns:
# NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# SUPABASE_URL
# SUPABASE_PUBLISHABLE_KEY
#
# O nome antigo VITE_SUPABASE_ANON_KEY ainda funciona, mas o Supabase novo
# mostra essa chave como Publishable key.
